# Cloudflare Workers Static Assets — custom response headers.
# Next.js emits its metadata image routes WITHOUT a file extension
# (/opengraph-image, /twitter-image, /apple-icon). Workers derives Content-Type
# from the extension, so without this these would serve as octet-stream and
# social scrapers (KakaoTalk, X, Facebook, Slack) would fail to preview them.
/opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400
/twitter-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400
/apple-icon
  Content-Type: image/png
  Cache-Control: public, max-age=86400

# pdf.js worker is loaded as a MODULE worker — the browser hard-rejects it unless
# served with a JS MIME. Force it so /pdf-to-jpg and /pdf-to-png work in prod.
/pdf.worker.min.mjs
  Content-Type: text/javascript
  Cache-Control: public, max-age=86400
